# Database (PostgreSQL - e.g. Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/complianceforge?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/complianceforge?sslmode=require"

# NextAuth (v5 / Auth.js)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Used by some integrations (e.g. GitHub App callbacks); often same as AUTH_URL
NEXTAUTH_URL="http://localhost:3000"

# AI providers — at least one required; NIM is tried first, then OpenRouter
# NVIDIA NIM API (direct, lower latency)
NIM_API_KEY="nvapi-your-key-here"
# OpenRouter (fallback, supports many models)
OPEN_ROUTER_KEY="sk-or-v1-your-key-here"

# GitHub App (for CI/CD integration)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Optional
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL=
ANTHROPIC_API_KEY=

# E2E (Playwright): set to skip local webServer and test a deployed URL
# BASE_URL=
